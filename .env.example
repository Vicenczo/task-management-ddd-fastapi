# ============================================================
# .env.example — Copy to .env and fill in production values
# ============================================================
# NEVER commit .env to version control.
# This file is safe to commit — contains no secrets.

# ── Application ──────────────────────────────────────────────
APP_NAME="Task & Project Management API"
APP_VERSION="0.1.0"
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────
# Development (docker-compose.yml):
DB_URL=postgresql+asyncpg://taskapi:taskapi_secret@localhost:5432/taskapi_db

# Production (override in docker-compose.prod.yml via environment: section)
POSTGRES_USER=taskapi
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=taskapi_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_MUST_BE_32_CHARS_MINIMUM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Gunicorn (production only) ───────────────────────────────
GUNICORN_WORKERS=3
LOG_LEVEL=info
PORT=8000